# ============================================================
# Fichiers a EXCLURE du contexte de build Docker.
# Sans ca, COPY embarquerait node_modules/ (plusieurs centaines de Mo)
# ainsi que dist/ deja existant sur la machine de dev.
# ============================================================

# Dependances : seront re-installees dans le container
node_modules/

# Build deja fait localement : on rebuild dans le container
dist/
.vite/

# Cache TypeScript / outils
*.tsbuildinfo
.eslintcache
.parcel-cache/

# IDE / outils dev
.vscode/
.idea/
*.swp
*.swo

# Logs et fichiers temporaires
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git
.git/
.gitignore

# Docker
Dockerfile
.dockerignore
# NB: nginx.conf est volontairement INCLUS dans le contexte de build :
# le Dockerfile fait `COPY nginx.conf /etc/nginx/conf.d/default.conf`.
