# ============================================================
# .env.example — Template des variables d'environnement
# ============================================================
# Copier ce fichier en `.env` a la racine du projet :
#   cp .env.example .env
# puis remplir les valeurs reelles. Le `.env` est lu automatiquement
# par docker-compose (variables ${...}) ET par le backend en mode local
# (via pydantic-settings).
#
# IMPORTANT : ne JAMAIS commiter le .env reel (deja dans .gitignore).
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=admin
POSTGRES_PASSWORD=monmotdepasse123
POSTGRES_DB=adaptive_learning

# Pour le backend en mode LOCAL (hors docker), URL avec localhost:5433.
# En mode docker, docker-compose surcharge automatiquement avec postgres:5432.
DATABASE_URL=postgresql+psycopg2://admin:monmotdepasse123@localhost:5433/adaptive_learning

# ---------- Neo4j ----------
NEO4J_USER=neo4j
NEO4J_PASSWORD=monmotdepasse123
# Pour le backend en mode LOCAL :
NEO4J_URI=bolt://localhost:7687

# ---------- JWT ----------
# Generer une vraie cle aleatoire en prod :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-me-in-production-use-a-random-32-byte-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- LLM ----------
# Provider : "ollama" (local, gratuit) ou "openai" (cloud, paye, qualite)
LLM_PROVIDER=openai

# Nom du modele (doit etre coherent avec le provider) :
#   ollama  -> "gemma-numerical-e2b"
#   openai  -> "gpt-4o-mini" (recommande), "gpt-4o", "gpt-3.5-turbo"
LLM_MODEL_NAME=gpt-4o-mini

# Hyperparametres du LLM
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Active le picker UI (cartes Gemma vs GPT cote frontend)
LLM_PICKER_ENABLED=true

# ---------- Ollama (modele local) ----------
OLLAMA_MODEL=gemma-numerical-e2b
# En mode LOCAL : http://localhost:11434
# En mode DOCKER : http://host.docker.internal:11434 (deja surcharge dans compose)
OLLAMA_BASE_URL=http://localhost:11434

# ---------- OpenAI (cloud) ----------
# Cle obtenue sur https://platform.openai.com/api-keys (commence par sk-...)
# Vide si LLM_PROVIDER=ollama uniquement.
OPENAI_API_KEY=

# ---------- Email (Phase 3 : verification + reset password) ----------
# Mode :
#   "console" (defaut) : log dans stdout, pas d'envoi reel (parfait dev/demo)
#   "smtp"             : envoi reel via SMTP (Gmail, SendGrid, etc.)
MAIL_MODE=console

# URL publique du frontend, utilisee dans les liens d'email.
FRONTEND_URL=http://localhost:4200

# Adresse expeditrice
MAIL_FROM=noreply@adaptive-learning.local
MAIL_FROM_NAME=Numera Platform

# Config SMTP (uniquement si MAIL_MODE=smtp)
# Exemple Gmail : SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_TLS=true
# avec un mot de passe d'application (PAS le password Google normal).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# Cooldown entre 2 envois d'email de verification pour le meme user
EMAIL_VERIFICATION_RESEND_COOLDOWN_SEC=60
EMAIL_VERIFICATION_TOKEN_HOURS=24
EMAIL_RESET_TOKEN_HOURS=1
